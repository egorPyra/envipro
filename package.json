{
  "name": "envipro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "export": "next export",
    "prebuild:desktop": "node scripts/swap_app.js desktop",
    "build:desktop": "next build && next export -o out/desktop",
    "postbuild:desktop": "node scripts/swap_app.js restore",
    "prebuild:mobile": "node scripts/swap_app.js mobile",
    "build:mobile": "next build && next export -o out/mobile",
    "postbuild:mobile": "node scripts/swap_app.js restore"
  },
  "dependencies": {
    "@types/node": "20.5.9",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.23",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "5.2.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.12",
    "sass": "^1.69.5"
  }
}
